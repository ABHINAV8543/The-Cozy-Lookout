<%- layout('layouts/boilerplate') %>

<style>
    .home-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 160px);
        text-align: center;
    }
    
    .home-title {
        font-size: 3.5rem;
        font-weight: 700;
        color: #f5f5f5;
        margin-bottom: 40px;
    }
    
    .home-title span {
        color: #ff4d8d;
    }

    .auth-buttons {
        display: flex;
        gap: 20px;
    }

    .btn-home {
        padding: 14px 28px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s;
        min-width: 140px;
    }

    .btn-primary {
        background: #ff4d8d;
        color: #111;
        border: 2px solid #ff4d8d;
    }

    .btn-primary:hover {
        background: #ff6b9e;
        border-color: #ff6b9e;
        box-shadow: 0 4px 15px rgba(255, 77, 141, 0.4);
        transform: translateY(-2px);
        color: #111;
    }

    .btn-secondary {
        background: transparent;
        color: #f5f5f5;
        border: 2px solid #333;
    }

    .btn-secondary:hover {
        border-color: #f5f5f5;
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-2px);
    }
</style>

<div class="home-container">
    <h1 class="home-title">Welcome to <span>The Cozy Lookout</span></h1>
    
    <div class="auth-buttons">
        <% if(!currUser) { %>
            <a href="/login" class="btn-home btn-primary">Log In</a>
            <a href="/signup" class="btn-home btn-secondary">Sign Up</a>
        <% } else { %>
            <a href="/listings" class="btn-home btn-primary">Explore Listings</a>
            <a href="/logout" class="btn-home btn-secondary">Log Out</a>
        <% } %>
    </div>
</div>