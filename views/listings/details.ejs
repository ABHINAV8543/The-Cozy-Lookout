<%- layout('layouts/boilerplate') %>

<% block('title', 'Listing Details') %>
<% block('head', '<link rel="stylesheet" href="/css/details.css">') %>


    <div class="outer-container">
        <div class="container">
            <h1 class="title"> <%= data.title %> </h1>
            <p style="color: #9ca3af; font-size: 0.95rem; margin-top: -10px; margin-bottom: 20px;">
                <i>Owned by @<%= owner ? owner.username : 'Unknown User' %></i>
            </p>
            <img src="<%= data.image.url %>" alt="" class="listing-img">
            <p class="description"> <%= data.description %> </p>
            <p class="location"> <%= data.location %> </p>
            <p class="price"> ₹<%= data.price.toLocaleString("en-in") %> </p>
            <% if(currUser && currUser._id.equals(owner._id)) { %>
                <div class="btn-container">
                    <a href="edit/<%= data._id %>"><button class="btn edit">Edit</button></a>
                    <button class="btn delete" onclick="confirmDelete('<%= data._id %>')">Delete</button>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="outer-container pt-0">
        <div class="container reviews-container">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #333333; padding-bottom: 10px;">
                <h2 class="review-title" style="margin-bottom: 0; border-bottom: none; padding-bottom: 0;">All Reviews</h2>
                <a href="/listings/<%= data._id %>/reviews/new" class="add-review-btn">Add a Review</a>
            </div>

    <% if(reviews.length > 0) { %>
            <div class="reviews-list">
                <% for(let review of reviews) { %>
                    <div class="review-card">
                        <div class="review-rating-display">
                            <% for(let i=1; i<=5; i++) { %>
                                <% if(i <= review.rating) { %>
                                    <i class="fa-solid fa-star gold-star"></i>
                                <% } else { %>
                                    <i class="fa-regular fa-star"></i>
                                <% } %>
                            <% } %>
                        </div>
                        <div class="review-header" style="margin-top: 5px; margin-bottom: 5px;">
                            <span style="font-weight: 600; font-size: 0.95rem; color: #ff4d8d;">@<%= authorMap[review.author.toString()] %></span>
                        </div>
                        <p class="review-comment"><%= review.comment %></p>
                        
                        <% if(currUser && currUser._id.equals(review.author)) { %>
                            <div class="review-actions">
                                <a href="/listings/<%= data._id %>/reviews/<%= review._id %>/edit" class="review-btn review-edit-btn" style="text-decoration: none;">Edit</a>
                                <form method="POST" action="/listings/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                                    <button type="submit" class="review-btn review-delete-btn">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
    <% } else { %>
            <p style="color: #cccccc;">No reviews yet. Be the first to leave one!</p>
    <% } %>
        </div>
    </div>

    <script>
        async function confirmDelete(id){
            if(confirm("Do you really want to delete this listing?")){
                const form = document.createElement("form");
                form.method = "POST";
                form.action = `/listings/${id}?_method=DELETE`;
                document.body.appendChild(form);
                form.submit();
            }
            else{
                console.log("Deletion Canceled");
            }
        }
    </script>
