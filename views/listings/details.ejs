<%- layout('layouts/boilerplate') %>

<% block('title', 'Listing Details') %>
<% block('head', '<link rel="stylesheet" href="/css/details.css">') %>


    <div class="outer-container">
        <div class="container">
            <div class="btn-container">
                <a href="edit/<%= data._id %>"><button class="btn edit">Edit</button></a>
                <button class="btn delete" onclick="confirmDelete('<%= data._id %>')">Delete</button>
            </div>
            <h1 class="title"> <%= data.title %> </h1>
            <img src="<%= data.image %>" alt="" class="listing-img">
            <p class="description"> <%= data.description %> </p>
            <p class="location"> <%= data.location %> </p>
            <p class="price"> ₹<%= data.price.toLocaleString("en-in") %> </p>
        </div>
    </div>
    <script>
        async function confirmDelete(id){
            if(confirm("Do you really want to delete this listing?")){
                const form = document.createElement("form");
                form.method = "POST";
                form.action = `/listings/${id}?_method=DELETE`;
                document.body.appendChild(form);
                form.submit();
            }
            else{
                console.log("Deletion Canceled");
            }
        }
    </script>