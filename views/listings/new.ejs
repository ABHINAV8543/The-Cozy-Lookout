<%- layout('layouts/boilerplate') %>

<% block('title', 'Add New Listing') %>
<% block('head', '<link rel="stylesheet" href="/css/new.css">') %>

<body>
    <div class="form-container">
        <h1>Add New Listing</h1>

        <form action="/listings" method="POST" class="listing-form">

            <div class="input-group">
                <label for="title">Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    placeholder="Luxury Villa with Sea View"
                    required
                >
            </div>

            <div class="input-group">
                <label for="image">Image URL</label>
                <input
                    type="text"
                    id="image"
                    name="image"
                    placeholder="https://example.com/image.jpg"
                    required
                >
            </div>

            <div class="input-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    rows="5"
                    placeholder="Describe your property..."
                    required
                ></textarea>
            </div>

            <div class="input-group">
                <label for="location">Location</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    placeholder="Noida, Uttar Pradesh, India"
                    required
                >
            </div>

            <div class="input-group">
                <label for="country">Country</label>
                <input
                    type="text"
                    id="country"
                    name="country"
                    placeholder="India"
                    required
                >
            </div>

            <div class="input-group">
                <label for="price">Price (₹)</label>
                <input
                    type="number"
                    id="price"
                    name="price"
                    placeholder="25000"
                    required
                >
            </div>

            <button type="submit" class="submit-btn">
                Add Listing
            </button>

        </form>
    </div>
</body>