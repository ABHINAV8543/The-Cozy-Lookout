<%- layout('layouts/boilerplate') %>

<% block('title', 'Edit Listing') %>
<% block('head', '<link rel="stylesheet" href="/css/new.css">') %>

    <div class="form-container">
        <h1>Edit Listing</h1>

        <form action="/listings/edit/<%= listing._id %>?_method=PUT" method="POST" class="listing-form">

            <div class="input-group">
                <label for="title">Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    value="<%= listing.title %>"
                    required
                >
            </div>

            <div class="input-group">
                <label for="image">Image URL</label>
                <input
                    type="text"
                    id="image"
                    name="image"
                    value="<%= listing.image %>"
                    required
                >
            </div>

            <div class="input-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    rows="5"
                    required
                ><%= listing.description %></textarea>
            </div>

            <div class="input-group">
                <label for="location">Location</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    value="<%= listing.location %>"
                    required
                >
            </div>

            <div class="input-group">
                <label for="country">Country</label>
                <input
                    type="text"
                    id="country"
                    name="country"
                    value="<%= listing.country %>"
                    required
                >
            </div>

            <div class="input-group">
                <label for="price">Price (₹)</label>
                <input
                    type="number"
                    id="price"
                    name="price"
                    value="<%= listing.price %>"
                    required
                >
            </div>

            <button type="submit" class="submit-btn">
                Save
            </button>

        </form>
    </div>