<%- layout('layouts/boilerplate') %>

<% block('title', 'Edit Listing') %>
<% block('head', '<link rel="stylesheet" href="/css/new.css">') %>

    <div class="form-container">
        <h1>Edit Listing</h1>

        <form action="/listings/edit/<%= listing._id %>?_method=PUT" method="POST" class="listing-form needs-validation" novalidate enctype="multipart/form-data">

            <div class="input-group">
                <label for="title">Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    value="<%= listing.title %>"
                    required
                >
                <div class="invalid-feedback">Please enter a valid title.</div>
            </div>

            <div class="input-group">
                <label for="image">Upload New Image</label>
                <input
                    type="file"
                    id="image"
                    name="image"
                    accept="image/*"
                >
                <div style="font-size: 0.8rem; color: #a3a3a3; margin-top: 5px;">Max file size: 5 MB. Formats: JPG, PNG, WEBP.</div>
                <div class="invalid-feedback">Please provide a valid image.</div>
            </div>

            <div class="input-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    rows="5"
                    required
                ><%= listing.description %></textarea>
                <div class="invalid-feedback">Please enter a description.</div>
            </div>

            <div class="input-group">
                <label for="location">Location</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    value="<%= listing.location %>"
                    required
                >
                <div class="invalid-feedback">Please provide a valid location.</div>
            </div>

            <div class="input-group">
                <label for="country">Country</label>
                <input
                    type="text"
                    id="country"
                    name="country"
                    value="<%= listing.country %>"
                    required
                >
                <div class="invalid-feedback">Please provide a country name.</div>
            </div>

            <div class="input-group">
                <label for="category">Category</label>
                <select id="category" name="category" required>
                    <option value="" disabled style="color: #000;">Select a Category</option>
                    <option value="Trending" style="color: #000;" <%= listing.category === 'Trending' ? 'selected' : '' %>>Trending</option>
                    <option value="Rooms" style="color: #000;" <%= listing.category === 'Rooms' ? 'selected' : '' %>>Rooms</option>
                    <option value="Iconic Cities" style="color: #000;" <%= listing.category === 'Iconic Cities' ? 'selected' : '' %>>Iconic Cities</option>
                    <option value="Mountains" style="color: #000;" <%= listing.category === 'Mountains' ? 'selected' : '' %>>Mountains</option>
                    <option value="Castles" style="color: #000;" <%= listing.category === 'Castles' ? 'selected' : '' %>>Castles</option>
                    <option value="Amazing Pools" style="color: #000;" <%= listing.category === 'Amazing Pools' ? 'selected' : '' %>>Amazing Pools</option>
                    <option value="Camping" style="color: #000;" <%= listing.category === 'Camping' ? 'selected' : '' %>>Camping</option>
                    <option value="Farms" style="color: #000;" <%= listing.category === 'Farms' ? 'selected' : '' %>>Farms</option>
                    <option value="Arctic" style="color: #000;" <%= listing.category === 'Arctic' ? 'selected' : '' %>>Arctic</option>
                    <option value="Domes" style="color: #000;" <%= listing.category === 'Domes' ? 'selected' : '' %>>Domes</option>
                    <option value="Boats" style="color: #000;" <%= listing.category === 'Boats' ? 'selected' : '' %>>Boats</option>
                </select>
                <div class="invalid-feedback">Please select a category.</div>
            </div>

            <div class="input-group">
                <label for="price">Price (₹)</label>
                <input
                    type="number"
                    id="price"
                    name="price"
                    value="<%= listing.price %>"
                    min="1"
                    required
                >
                <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <button type="submit" class="submit-btn">
                Save
            </button>

        </form>
    </div>